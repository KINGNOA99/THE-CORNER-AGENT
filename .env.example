# ==============================================
# THE CORNER - Social Media Automation Config
# ==============================================

# FACEBOOK
FACEBOOK_TOKEN=your_facebook_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# INSTAGRAM
INSTAGRAM_TOKEN=your_instagram_business_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# TIKTOK
TIKTOK_TOKEN=your_tiktok_api_token_here

# WHATSAPP
WHATSAPP_TOKEN=your_whatsapp_business_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id_here
WHATSAPP_RECIPIENT=27812345678

# GENERAL
NODE_ENV=production
LOG_LEVEL=info